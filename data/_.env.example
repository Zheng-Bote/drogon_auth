# Database Configuration
# Set DB_TYPE to 'postgres' or 'sqlite3'
DB_TYPE=postgres

# PostgreSQL Configuration (used if DB_TYPE=postgres)
DB_HOST=psql_server
DB_PORT=5432
DB_NAME=gallery
DB_USER=gallery_user
DB_PASSWORD=supersecret

# SQLite3 Configuration (used if DB_TYPE=sqlite3)
SQLITE_FILE=data/gallery.sqlite3

Security
JWT_SECRET=change_me_to_a_long_random_string
TOTP_ISSUER=PhotoGallery
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=1

SERVER_PORT=8848
SESSION_TTL_SECONDS=3600
SERVER_PORT=8849
SESSION_TTL_SECONDS=3600
ADMIN_PASSWORD=your_admin_db_password
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USER=admin

# see config.example.json
DROGON_CONFIG_FILE=data/drogon_config.json
